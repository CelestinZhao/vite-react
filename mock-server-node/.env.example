# AiChat Mock Server 环境变量模板
# 复制本文件为 .env.local，填入真实密钥；.env.local 不会被提交到 git
#
# ⚠️ 密钥仅从环境变量读取，代码与日志中不会出现。
# 未配置任何 Provider 时，所有模型自动降级到内置 mock，保证开箱即用。

# ========== 基础配置 ==========
# 服务端口
MOCK_PORT=3001

# 上下文窗口大小（每次最多带多少条历史消息给模型）
CONTEXT_MESSAGE_LIMIT=20

# ========== OpenAI ==========
# 官方地址：https://api.openai.com/v1
# 也可替换为任意 OpenAI 兼容代理
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# ========== Anthropic (Claude) ==========
ANTHROPIC_API_KEY=

# ========== 混元（腾讯） ==========
# OpenAI 兼容协议
HUNYUAN_API_KEY=
HUNYUAN_BASE_URL=https://api.hunyuan.cloud.tencent.com/v1

# ========== DeepSeek ==========
# OpenAI 兼容协议
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

