{
	"name": "vite-react",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"start": "vite",
		"start:force": "vite --force",
		"build": "vite build",
		"build:analyze": "cross-env ANALYZE=true vite build",
		"lint": "eslint . --report-unused-disable-directives --max-warnings 0",
		"type-check": "tsc --noEmit",
		"audit:ci": "npm audit --audit-level=critical",
		"stylelint": "stylelint \"src/**/*.{css,less}\"",
		"stylelint:fix": "stylelint \"src/**/*.{css,less}\" --fix",
		"format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,less,md}\"",
		"format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,json,css,less,md}\"",
		"preview": "vite preview"
	},
	"dependencies": {
		"@dnd-kit/core": "^6.1.0",
		"@dnd-kit/sortable": "^8.0.0",
		"@dnd-kit/utilities": "^3.2.2",
		"@hello-pangea/dnd": "^16.6.0",
		"lodash": "^4.17.21",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"react-markdown": "^10.1.0",
		"react-router-dom": "^6.23.1",
		"remark-gfm": "^4.0.1",
		"tdesign-icons-react": "^0.3.5",
		"tdesign-react": "^1.16.8",
		"tesseract.js": "^5.1.1",
		"xlsx": "^0.18.5"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@types/node": "^25.6.0",
		"@types/react": "^18.3.1",
		"@types/react-dom": "^18.3.1",
		"@vitejs/plugin-react": "^4.7.0",
		"cross-env": "^10.1.0",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-react": "^7.37.5",
		"eslint-plugin-react-hooks": "^5.2.0",
		"eslint-plugin-react-refresh": "^0.4.26",
		"globals": "^15.15.0",
		"less": "^4.2.0",
		"postcss-less": "^6.0.0",
		"prettier": "^3.8.3",
		"rollup-plugin-visualizer": "^7.0.1",
		"stylelint": "^17.8.0",
		"stylelint-config-css-modules": "^4.6.0",
		"stylelint-config-standard": "^40.0.0",
		"stylelint-config-standard-less": "^4.1.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.0",
		"vite": "^6.4.2",
		"vite-plugin-externals": "^0.6.2"
	}
}
